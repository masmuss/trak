{
	"name": "@trak/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:seed": "node --import tsx/esm --env-file=../../.env src/lib/server/db/seed.ts"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@fontsource-variable/geist": "^5.2.9",
		"@fontsource-variable/manrope": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.3",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.48",
		"phosphor-svelte": "^3.1.0",
		"playwright": "^1.59.1",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.0.0",
		"tw-animate-css": "^1.4.0",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@tanstack/table-core": "^8.21.3",
		"@trak/database": "workspace:*",
		"@trak/services": "workspace:*",
		"@trak/shared": "workspace:*",
		"better-auth": "^1.6.11",
		"better-call": "^1.3.5",
		"drizzle-orm": "^0.45.2",
		"drizzle-seed": "^0.3.1",
		"drizzle-zod": "^0.8.3",
		"mode-watcher": "^1.1.0",
		"postgres": "^3.4.9",
		"zod": "^4.4.3"
	}
}
